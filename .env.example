# Copy this file, rename to .env, and fill in your values
# Then copy-paste each key=value pair into Railway Variables UI

ROBLOX_API_KEY=your-api-key-from-create.roblox.com-credentials
ROBLOX_COOKIE=your-.ROBLOSECURITY-cookie-from-browser-devtools
GROUP_ID=your-group-numeric-id
HORNS_RANK_ID=the-role-id-to-assign-horn-owners
ACCEPT_PENDING=true
RANK_MEMBERS=true
DECLINE_NON_OWNERS=true
DRY_RUN=true
DISCORD_WEBHOOK=
